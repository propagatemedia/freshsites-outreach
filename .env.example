# FreshSites Environment Configuration
# Add your Stripe API keys here

# Stripe Secret Key (sk_test_... for test, sk_live_... for production)
STRIPE_SECRET_KEY=

# Stripe Publishable Key (pk_test_... for test, pk_live_... for production)  
STRIPE_PUBLISHABLE_KEY=

# Stripe Payment Links (create these in your Stripe Dashboard)
STRIPE_LINK_BUY_OUTRIGHT=
STRIPE_LINK_HOSTED_EDITS=
STRIPE_LINK_PREMIUM=

# Vercel API Token (for automated deployment after purchase)
VERCEL_API_TOKEN=

# Email for change requests / support
SUPPORT_EMAIL=tyrone@propagate.media
